    <script>
        // --- DATA ---
        const briefsData = [
            {
                id: 'RTN-03-992', title: 'סרום רטינול 0.3% PRO', status: 'Active',
                context: 'פורמולה חדשה המכילה ריכוז פעיל של 0.3% רטינול טהור. מיועדת לשימוש לילה בלבד עקב רגישות לשמש.',
                approvedClaims: ['מסייע בחידוש מראה העור', 'תורם לגוון עור אחיד יותר', 'מוכח קלינית כמשפר מרקם'],
                redLinesText: ['חל איסור להשתמש במילה <strong>"תרופה"</strong> או <strong>"רפואי"</strong>.', 'חל איסור לטעון שזה <strong>"מעלים קמטים"</strong>.', 'חל איסור לרמוז על <strong>"שימוש ביום/בשמש"</strong>.'],
                forbiddenWords: ['תרופה', 'רפואי', 'מעלים קמטים', 'שמש', 'ביום', 'יום'],
                demoTip: 'נסה לכתוב את המילה <b>"תרופה"</b> או <b>"מעלים קמטים"</b>.'
            },
            {
                id: 'AHA-10-EXF', title: 'פילינג חומצות AHA 10%', status: 'Flagged (Regulatory)',
                context: 'פילינג כימי חזק לשימוש ביתי פעם עד פעמיים בשבוע. מכיל חומצה גליקולית.',
                approvedClaims: ['מסיר תאים מתים ביעילות', 'מעניק מראה עור קורן וזוהר'],
                redLinesText: ['חל איסור מוחלט לכתוב <strong>"לשימוש יומיומי"</strong>.', 'אסור לטעון שזה <strong>"מתאים לכל סוגי העור"</strong>.'],
                forbiddenWords: ['לשימוש יומיומי', 'כל סוגי העור', 'פעם ביום'],
                demoTip: 'בריף זה ממתין לעדכון גרסה (v2.0) עקב הנחיה רגולטורית חדשה.'
            }
        ];

        let currentActiveBrief = null;
        let currentAssetType = 'marketing';

        window.onload = () => { renderBriefs(); };

        function renderBriefs() {
            const container = document.getElementById('briefs-container');
            container.innerHTML = ''; 

            briefsData.forEach(brief => {
                const claimsHtml = brief.approvedClaims.map(claim => `<li>• ${claim}</li>`).join('');
                const redLinesHtml = brief.redLinesText.map(line => `<li>• ${line}</li>`).join('');
                
                const statusColor = brief.id === 'AHA-10-EXF' ? 'bg-orange-100 text-orange-800' : 'bg-blue-100 text-blue-800';
                const actionButton = brief.id === 'AHA-10-EXF' 
                    ? `<button onclick="switchTab('lifecycle')" class="bg-brand-orange text-white px-6 py-2 rounded-lg font-medium hover:bg-orange-600 transition shadow-md flex items-center gap-2"><i class="fa-solid fa-triangle-exclamation"></i> טפל בהתראה רגולטורית</button>`
                    : `<button onclick="selectBrief('${brief.id}')" class="bg-brand-dark text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-900 transition shadow-md flex items-center gap-2"><i class="fa-solid fa-pen-nib"></i> צור תוכן מבריף זה</button>`;

                const briefCard = `
                    <div class="bg-white rounded-xl shadow-sm border ${brief.id === 'AHA-10-EXF' ? 'border-brand-orange' : 'border-slate-200'} overflow-hidden relative">
                        <!-- ADDED: InfoSec / RBAC Read-Only Badge -->
                        <div class="absolute top-4 left-6 flex items-center gap-2 text-xs font-bold text-slate-400 bg-slate-100 px-3 py-1 rounded">
                            <i class="fa-solid fa-lock text-brand-dark"></i> View-Only (SSOT)
                        </div>

                        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex justify-between items-center">
                            <div class="flex items-center gap-3 mt-1">
                                <span class="${statusColor} text-xs font-bold px-2.5 py-1 rounded shadow-sm">${brief.status}</span>
                                <h3 class="font-bold text-lg text-brand-dark">${brief.title}</h3>
                            </div>
                        </div>
                        <div class="p-6">
                            <p class="text-slate-600 mb-6 border-r-4 border-slate-300 pr-4 leading-relaxed"><strong>הקשר קליני:</strong> ${brief.context}</p>
                            <div class="grid grid-cols-2 gap-6">
                                <div class="bg-green-50 rounded-lg p-5 border border-green-100">
                                    <h4 class="font-bold text-green-800 flex items-center gap-2 mb-3"><i class="fa-solid fa-check-circle"></i> טענות מאושרות (Claims)</h4>
                                    <ul class="space-y-2 text-sm text-green-900">${claimsHtml}</ul>
                                </div>
                                <div class="bg-red-50 rounded-lg p-5 border border-red-100">
                                    <h4 class="font-bold text-red-800 flex items-center gap-2 mb-3"><i class="fa-solid fa-ban"></i> קווים אדומים (Red Lines)</h4>
                                    <ul class="space-y-2 text-sm text-red-900 font-medium">${redLinesHtml}</ul>
                                </div>
                            </div>
                        </div>
                        <div class="bg-slate-50 border-t border-slate-100 px-6 py-4 flex justify-between items-center">
                            <span class="text-sm font-mono text-slate-500 bg-white px-2 py-1 border border-slate-200 rounded shadow-sm">ID: #${brief.id}</span>
                            ${actionButton}
                        </div>
                    </div>
                `;
                container.innerHTML += briefCard;
            });
        }

        function switchTab(tabId) {
            ['brief', 'creator', 'pipeline', 'lifecycle'].forEach(id => {
                document.getElementById('tab-' + id).classList.add('hidden');
                document.getElementById('nav-' + id).classList.remove('bg-white/10', 'text-white', 'border', 'border-brand-orange');
                document.getElementById('nav-' + id).classList.add('text-slate-300');
            });
            
            document.getElementById('tab-' + tabId).classList.remove('hidden');
            
            if(tabId === 'lifecycle') {
                document.getElementById('nav-lifecycle').classList.add('border', 'border-brand-orange', 'text-white');
                document.getElementById('nav-lifecycle').classList.remove('text-slate-300');
            } else {
                document.getElementById('nav-' + tabId).classList.add('bg-white/10', 'text-white');
            }

            const titles = {
                'brief': 'מאגר האמת הארגוני (SSOT)',
                'creator': 'ממשק יצירה: שיווק והדרכה',
                'pipeline': 'שער תיקוף אופרטיבי (Ops Gate)',
                'lifecycle': 'ניהול מחזור חיי ידע (Lifecycle)'
            };
            document.getElementById('page-title').innerText = titles[tabId];
        }

        // --- CREATOR & VALIDATION LOGIC ---
        function selectBrief(briefId) {
            currentActiveBrief = briefsData.find(b => b.id === briefId);
            document.getElementById('nav-creator').classList.remove('pointer-events-none', 'opacity-50');
            document.getElementById('nav-pipeline').classList.remove('pointer-events-none', 'opacity-50');
            document.getElementById('active-brief-id').innerText = '#' + currentActiveBrief.id;
            document.getElementById('active-brief-title').innerText = currentActiveBrief.title;
            document.getElementById('active-demo-tip').innerHTML = currentActiveBrief.demoTip;
            document.getElementById('camp-text').value = ''; 
            document.querySelector('input[name="asset_type"][value="marketing"]').checked = true;
            updateCreatorUI();
            switchTab('creator');
        }

        function updateCreatorUI() {
            const selected = document.querySelector('input[name="asset_type"]:checked').value;
            currentAssetType = selected;
            const nameInput = document.getElementById('camp-name');
            const labelName = document.getElementById('label-camp-name');
            
            if(selected === 'marketing') {
                labelName.innerText = "שם הקמפיין (Marketing Asset)";
                nameInput.value = `פוסט השקה - ${currentActiveBrief.title}`;
            } else {
                labelName.innerText = "שם פרוטוקול ההדרכה (Training Asset)";
                nameInput.value = `פרוטוקול קליניקה לצוות - ${currentActiveBrief.title}`;
            }
        }

        function submitToValidation() {
            const text = document.getElementById('camp-text').value.trim();
            if(!text) return alert("אנא הקלד תוכן כלשהו לבדיקה.");

            document.getElementById('pipeline-badge').classList.remove('hidden');
            document.getElementById('pipeline-empty').classList.add('hidden');
            document.getElementById('pipeline-task').classList.remove('hidden');
            document.getElementById('val-camp-name').innerText = document.getElementById('camp-name').value;
            document.getElementById('val-ref-id').innerText = '#' + currentActiveBrief.id;
            document.getElementById('val-text').innerText = `"${text}"`;

            const badge = document.getElementById('val-asset-badge');
            if(currentAssetType === 'marketing') {
                badge.className = "bg-brand-accent text-white text-xs font-bold px-3 py-1 rounded border border-white/20";
                badge.innerHTML = '<i class="fa-solid fa-bullhorn ml-1"></i> שיווק (B2C)';
            } else {
                badge.className = "bg-brand-purple text-white text-xs font-bold px-3 py-1 rounded border border-white/20";
                badge.innerHTML = '<i class="fa-solid fa-person-chalkboard ml-1"></i> הדרכה (B2B)';
            }

            runValidationGate(text);
            switchTab('pipeline');
        }

        function runValidationGate(text) {
            const valSystem = document.getElementById('validation-system');
            const actionBtns = document.getElementById('action-buttons');
            let violations = [];
            currentActiveBrief.forbiddenWords.forEach(word => { if(text.includes(word)) violations.push(word); });
            const assetTypeName = currentAssetType === 'marketing' ? 'הקמפיין השיווקי' : 'פרוטוקול ההדרכה';

            if(violations.length > 0) {
                valSystem.className = "rounded-lg p-5 mb-6 border bg-red-50 border-red-200 shadow-inner";
                valSystem.innerHTML = `<div class="flex items-start gap-4"><div class="mt-1 text-red-600 text-2xl"><i class="fa-solid fa-hand"></i></div><div><h4 class="font-bold text-red-800 text-lg">חסם תפעולי הופעל (Hard Stop)</h4><p class="text-red-700 mt-1">המערכת זיהתה חריגה מגבולות הגזרה המוגדרים בבריף <span class="font-mono bg-red-100 px-1 rounded">#${currentActiveBrief.id}</span>.</p><p class="text-red-700 mt-1 font-bold">שימו לב: דין תוצר הדרכה כדין תוצר שיווקי מבחינת Compliance.</p><div class="mt-3 bg-white p-3 border border-red-100 rounded text-red-900 text-sm shadow-sm"><strong>מילים אסורות שאותרו בטקסט:</strong> <span class="font-bold">${violations.join(', ')}</span></div><p class="text-sm font-bold text-red-800 mt-3 flex items-center gap-2"><i class="fa-solid fa-circle-xmark"></i> ${assetTypeName} נחסם ולא יועבר לאישור ה-SME.</p></div></div>`;
                actionBtns.innerHTML = `<button onclick="rejectToMarketing()" class="bg-red-600 text-white px-6 py-2 rounded-lg font-bold hover:bg-red-700 transition flex items-center gap-2 shadow-md"><i class="fa-solid fa-rotate-left"></i> דחה והחזר ליוצר לתיקון</button>`;
            } else {
                valSystem.className = "rounded-lg p-5 mb-6 border bg-green-50 border-green-200 shadow-inner";
                valSystem.innerHTML = `<div class="flex items-start gap-4"><div class="mt-1 text-green-600 text-2xl"><i class="fa-solid fa-check-double"></i></div><div><h4 class="font-bold text-green-800 text-lg">תיקוף אופרטיבי עבר בהצלחה</h4><p class="text-green-700 mt-1">${assetTypeName} תואם במלואו לטענות המאושרות בבריף ואינו מכיל חריגות בטיחותיות.</p><p class="text-sm font-bold text-green-800 mt-3 flex items-center gap-2"><i class="fa-solid fa-hourglass-half"></i> התוצר ממתין כעת לאישור סופי (עובדתי) של מומחה התוכן (SME).</p></div></div>`;
                
                // ADDED: SLA Timer explicit callout for SME handoff
                actionBtns.innerHTML = `
                    <div class="flex items-center gap-4 w-full justify-between">
                        <span class="text-xs text-slate-400 font-mono"><i class="fa-solid fa-clock"></i> Ops Gate cleared in 12m. Handoff to SME...</span>
                        <button onclick="simulateSMEApproval()" class="bg-brand-dark text-white px-6 py-2 rounded-lg font-bold hover:bg-blue-900 transition flex items-center gap-2 shadow-md"><i class="fa-solid fa-microscope"></i> אישור מומחה תוכן (SME)</button>
                    </div>`;
            }
        }

        function rejectToMarketing() {
            document.getElementById('pipeline-badge').classList.add('hidden');
            switchTab('creator');
        }

        function simulateSMEApproval() {
            const prefix = currentAssetType === 'marketing' ? 'CMP' : 'TRN';
            const metaId = prefix + '-' + Math.floor(1000 + Math.random() * 9000) + '-A';
            document.getElementById('validation-system').className = "rounded-lg p-5 mb-6 border bg-blue-50 border-blue-200 shadow-inner";
            document.getElementById('validation-system').innerHTML = `<div class="flex items-start gap-4"><div class="mt-1 text-brand-accent text-3xl"><i class="fa-solid fa-link"></i></div><div class="w-full"><h4 class="font-bold text-brand-dark text-lg">תוצר אושר והופץ!</h4><div class="mt-4 bg-white p-4 border border-blue-100 rounded flex flex-col gap-3"><div class="flex justify-between items-center border-b border-slate-100 pb-2"><span class="text-slate-500 text-sm font-medium">מקור אמת (בריף):</span><span class="text-slate-800 font-mono text-sm font-bold">#${currentActiveBrief.id}</span></div><div class="flex justify-between items-center"><span class="text-blue-900 text-sm font-bold">מזהה Metadata נגזר:</span><span class="bg-brand-dark text-white font-mono text-sm font-bold px-3 py-1 rounded">${metaId}</span></div></div></div></div>`;
            document.getElementById('action-buttons').innerHTML = `<button onclick="resetDemo()" class="bg-slate-200 text-slate-700 px-6 py-2 rounded-lg font-bold hover:bg-slate-300 transition"><i class="fa-solid fa-house"></i> חזור למאגר</button>`;
            document.getElementById('pipeline-badge').classList.add('hidden');
        }

        function resetDemo() { switchTab('brief'); }

        function triggerCascade() {
            document.getElementById('lifecycle-alert').classList.add('hidden');
            document.getElementById('lifecycle-success').classList.remove('hidden');
            document.querySelector('#nav-lifecycle span.absolute').classList.add('hidden');
            document.getElementById('nav-lifecycle').classList.remove('border', 'border-brand-orange');
            
            const ahaBriefIndex = briefsData.findIndex(b => b.id === 'AHA-10-EXF');
            if(ahaBriefIndex !== -1) {
                briefsData[ahaBriefIndex].status = 'Active v2.0';
                briefsData[ahaBriefIndex].title = 'פילינג חומצות AHA 8% (מעודכן)';
                renderBriefs();
            }
        }
    </script>
</body>
</html>
